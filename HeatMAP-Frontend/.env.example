# ─────────────────────────────────────────────────────────────────
# Heatwave AI — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# All EXPO_PUBLIC_* variables are bundled at build time and exposed
# to the client — do NOT put secrets here.
# ─────────────────────────────────────────────────────────────────

# ── Backend (Render) ─────────────────────────────────────────────
# The full URL of your Render deployment (no trailing slash).
# Find it in the Render dashboard → your service → "Your service's URL".
# Example: https://heatwave-ai-backend.onrender.com
EXPO_PUBLIC_API_URL=https://heatwave-backend-elysia.onrender.com

# ── Google Maps (optional) ───────────────────────────────────────
# Required only if you want Google Places results for cooling centres.
# If omitted, the app falls back to the free OpenStreetMap Overpass API.
# Get a key at: https://console.cloud.google.com/
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
